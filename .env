# ============================================================
# .env — LOCAL DEVELOPMENT ONLY
# DO NOT commit real secrets. This file is in .gitignore.
# Copy .env.example and fill in real values.
# ============================================================

# Flask core
FLASK_SECRET_KEY=replace-with-a-strong-random-secret
DATABASE_PATH=postpilot.db
TOKEN_ENCRYPTION_KEY=replace-with-output-of: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"

# App environment
APP_ENV=development
FLASK_ENV=development

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
DATABASE_URL=postgresql://postgres.your-project:password@aws-0-us-west-2.pooler.supabase.com:5432/postgres

# OpenAI
OPENAI_API_KEY=sk-...

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_STARTER=price_...
STRIPE_PRICE_GROWTH=price_...
STRIPE_PRICE_AGENCY=price_...

# OAuth redirect URIs (local)
REDIRECT_URI=http://localhost:5000/auth/facebook/callback
GOOGLE_REDIRECT_URI=http://localhost:5000/auth/google/callback
TIKTOK_REDIRECT_URI=http://localhost:5000/auth/tiktok/callback
TWITTER_REDIRECT_URI=http://localhost:5000/auth/twitter/callback

# Dev login (leave empty to disable)
DEV_LOGIN_KEY=

# Redis (leave empty to use in-memory fallback in dev)
REDIS_URL=
