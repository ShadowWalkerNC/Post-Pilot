# PostPilot Pro — All API Keys
# ──────────────────────────────────────────────

# 📘 META (Facebook + Instagram)
# https://developers.facebook.com/apps/
FACEBOOK_APP_ID=your_facebook_app_id
FACEBOOK_APP_SECRET=your_facebook_app_secret
REDIRECT_URI=http://localhost:5000/auth/facebook/callback

# 📍 GOOGLE (Google Business + YouTube)
# https://console.cloud.google.com/
# Enable: Business Profile API + YouTube Data API v3
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=http://localhost:5000/auth/google/callback

# 🎵 TIKTOK
# https://developers.tiktok.com/
TIKTOK_CLIENT_KEY=your_tiktok_client_key
TIKTOK_CLIENT_SECRET=your_tiktok_client_secret
TIKTOK_REDIRECT_URI=http://localhost:5000/auth/tiktok/callback

# 🌐 WEBSITE BANNER (no key needed)
# Just add to your site's <head>:
# <script src="https://YOUR-DEPLOYED-URL/static/embed.js"></script>
WEBSITE_URL=https://yourwebsite.com

# APP
FLASK_SECRET_KEY=change-this-to-a-random-string
FLASK_ENV=development
DATABASE_URL=sqlite:///app.db
