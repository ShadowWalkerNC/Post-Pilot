# ═══════════════════════════════════════════════════════
# Post-Pilot — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ═══════════════════════════════════════════════════════

# ── Flask core ──────────────────────────────────────────
FLASK_SECRET_KEY=change-me-to-a-random-32-char-string
DATABASE_PATH=postpilot.db

# ── App environment ─────────────────────────────────────
APP_ENV=development
FLASK_ENV=development

# ── OpenAI (required for AI caption generation) ─────────
OPENAI_API_KEY=sk-...

# ── Stripe (required for billing) ───────────────────────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_STARTER=price_...
STRIPE_PRICE_GROWTH=price_...
STRIPE_PRICE_AGENCY=price_...

# ── Redis (REQUIRED in production for rate limiting) ─────
# Without this, each gunicorn worker has its own rate-limit counter.
# Local dev: leave commented out (falls back to memory://).
# REDIS_URL=redis://default:<password>@<host>:<port>

# ── Meta — Facebook Pages + Instagram Business ──────────
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
REDIRECT_URI=http://localhost:5000/auth/facebook/callback
# Production: https://<your-domain>/auth/facebook/callback

# ── Google — Business Profile + YouTube ─────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:5000/auth/google/callback
# Production: https://<your-domain>/auth/google/callback

# ── TikTok ──────────────────────────────────────────────
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
TIKTOK_REDIRECT_URI=http://localhost:5000/auth/tiktok/callback
# Production: https://<your-domain>/auth/tiktok/callback

# ── Twitter / X ──────────────────────────────────────────
# Create an app at https://developer.twitter.com/
# App type: Web App  (enables client_secret + PKCE)
# Required scopes: tweet.read  tweet.write  users.read  offline.access
# Register callback URL in app settings.
TWITTER_CLIENT_ID=
TWITTER_CLIENT_SECRET=
TWITTER_REDIRECT_URI=http://localhost:5000/auth/twitter/callback
# Production: https://<your-domain>/auth/twitter/callback
