{
  "version": 2,
  "builds": [
    { "src": "app.py", "use": "@vercel/python" }
  ],
  "routes": [
    { "src": "/(.*)", "dest": "app.py" }
  ],
  "crons": [
    {
      "path": "/api/cron/generate",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/cron/publish",
      "schedule": "* * * * *"
    }
  ]
}
